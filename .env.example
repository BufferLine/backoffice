# ── Environment ──
ENVIRONMENT=development  # development | production

# ── Database (Supabase or local PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── File Storage (Supabase Storage, Cloudflare R2, or MinIO) ──
S3_ENDPOINT=https://xxx.supabase.co/storage/v1/s3
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=backoffice
S3_REGION=auto  # needed for some providers

# ── Auth ──
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000  # external URL for setup links
CORS_ORIGINS=http://localhost:3000  # comma-separated

# ── Local Dev Only ──
DB_PASSWORD=devpassword123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=miniodevpassword123
