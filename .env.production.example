ENVIRONMENT=production

# ── Database (Supabase) ──
DATABASE_URL=postgresql+asyncpg://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── File Storage (Cloudflare R2) ──
# R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_BUCKET=backoffice
S3_REGION=auto

# ── Auth ──
JWT_SECRET=generate-a-random-64-char-string-here

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=https://backoffice.yourdomain.com
CORS_ORIGINS=https://backoffice.yourdomain.com

# ── Docker ──
BACKOFFICE_PORT=8080  # nginx exposed port (cloudflared points here)
CLOUDFLARED_CONFIG_DIR=~/.cloudflared
